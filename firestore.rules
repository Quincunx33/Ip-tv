rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // Role-based helper matching specifically our admin user taaissu@gmail.com
    function isAdmin() {
      return isSignedIn() && 
             request.auth.token.email == 'taaissu@gmail.com' && 
             request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isValidFavorites(arr) {
      return arr is list && arr.size() <= 5000;
    }

    function isValidStringArray(arr) {
      return arr is list && arr.size() <= 5000;
    }

    function isValidUser(data) {
      return data.keys().size() <= 2 &&
             (data.keys().hasAny(['favorites']) ? isValidFavorites(data.favorites) : true) &&
             (data.keys().hasAny(['deadChannels']) ? isValidStringArray(data.deadChannels) : true);
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['favorites', 'deadChannels']);
      allow delete: if isOwner(userId);

      match /interactions/{interactionId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /m3u_playlists/{playlistId} {
      allow read: if true; // Any visitor can view loaded custom channels
      allow create: if isAdmin() && 
                      isValidId(playlistId) &&
                      request.resource.data.keys().hasAll(['name', 'url', 'server', 'addedBy', 'createdAt']) &&
                      request.resource.data.keys().size() == 5 &&
                      request.resource.data.name is string && request.resource.data.name.size() <= 200 &&
                      request.resource.data.url is string && request.resource.data.url.size() <= 2000 &&
                      request.resource.data.server is string && (request.resource.data.server == '1' || request.resource.data.server == '2' || request.resource.data.server == '3') &&
                      request.resource.data.addedBy == request.auth.token.email &&
                      request.resource.data.createdAt == request.time;
      allow update: if isAdmin() && 
                      isValidId(playlistId) &&
                      request.resource.data.keys().hasAll(['name', 'url', 'server', 'addedBy', 'createdAt']) &&
                      request.resource.data.keys().size() == 5 &&
                      request.resource.data.name is string && request.resource.data.name.size() <= 200 &&
                      request.resource.data.url is string && request.resource.data.url.size() <= 2000 &&
                      request.resource.data.server is string && (request.resource.data.server == '1' || request.resource.data.server == '2' || request.resource.data.server == '3') &&
                      request.resource.data.addedBy == resource.data.addedBy &&
                      request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isAdmin() && isValidId(playlistId);
    }

    match /messages/{messageId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
