rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidChannel(channel) {
      return channel is map &&
             channel.keys().hasAll(['url', 'name']) &&
             channel.url is string &&
             channel.name is string;
    }

    function isValidFavorites(arr) {
      return arr is list && arr.size() <= 5000;
    }

    function isValidStringArray(arr) {
      return arr is list && arr.size() <= 5000;
    }

    function isValidUser(data) {
      return data.keys().size() <= 2 &&
             (data.keys().hasAny(['favorites']) ? isValidFavorites(data.favorites) : true) &&
             (data.keys().hasAny(['deadChannels']) ? isValidStringArray(data.deadChannels) : true);
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['favorites', 'deadChannels']);
      allow delete: if isOwner(userId);

      match /interactions/{interactionId} {
        allow read, write: if isOwner(userId);
      }
    }

    match /messages/{messageId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
