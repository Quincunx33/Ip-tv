{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build:static-api": "tsx scripts/generate-static-api.ts",
    "build": "npm run build:static-api && vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.22.2",
    "firebase": "^12.14.0",
    "framer-motion": "^12.40.0",
    "hls.js": "^1.6.16",
    "http-proxy-agent": "^9.1.0",
    "https-proxy-agent": "^9.1.0",
    "lucide-react": "^0.546.0",
    "m3u8-parser": "^7.2.0",
    "motion": "^12.23.24",
    "node-fetch": "^3.3.2",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-firebase-hooks": "^5.1.1",
    "socks-proxy-agent": "^10.1.0",
    "tailwind-merge": "^3.6.0",
    "vite": "^6.2.3",
    "workbox-precaching": "^7.4.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "puppeteer": "^25.1.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vite-plugin-pwa": "^1.3.0"
  }
}
