{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and preferences",
      "type": "object",
      "properties": {
        "favorites": {
          "type": "array",
          "items": { 
             "type": "object",
             "properties": {
                "name": { "type": "string" },
                "url": { "type": "string" },
                "logo": { "type": "string" }
             }
          },
          "description": "List of favorite channels"
        },
        "deadChannels": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of dead channel URLs"
        }
      }
    },
    "Message": {
      "title": "Message",
      "description": "Live chat message",
      "type": "object",
      "properties": {
        "channelId": { "type": "string" },
        "uid": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "timestamp" }
      }
    },
    "Interaction": {
      "title": "Interaction",
      "description": "User like or dislike on a channel",
      "type": "object",
      "properties": {
        "channelId": { "type": "string" },
        "type": { "type": "string", "enum": ["like", "dislike"] }
      }
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user preferences and data."
    },
    "messages/{messageId}": {
      "schema": {
        "$ref": "#/entities/Message"
      },
      "description": "Live chat messages."
    },
    "users/{userId}/interactions/{interactionId}": {
      "schema": {
        "$ref": "#/entities/Interaction"
      },
      "description": "User interactions."
    }
  }
}
